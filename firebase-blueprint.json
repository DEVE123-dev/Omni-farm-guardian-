{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile storage",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "AnimalRecord": {
      "title": "Animal Record",
      "description": "Health scan record for an animal",
      "type": "object",
      "properties": {
        "species": { "type": "string" },
        "healthScore": { "type": "number" },
        "observations": { "type": "string" },
        "recommendedAction": { "type": "string" },
        "photoUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "animalId": { "type": "string", "description": "Optional ID for a specific recurring animal" }
      },
      "required": ["species", "healthScore", "userId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "/animals/{animalId}": {
      "schema": "AnimalRecord",
      "description": "Livestock health records"
    }
  }
}
